
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write to the main collections
    match /{collection}/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    // Allow authenticated users to read and write to subcollections
    match /{collection}/{docId}/{subcollection}/{subDocId} {
      allow read, write: if isAuthenticated();
    }
  }
}
